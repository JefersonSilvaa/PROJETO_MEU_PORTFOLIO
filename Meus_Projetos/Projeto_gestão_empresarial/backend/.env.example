PORT=3001
# Opcional: force mysql ou sqlite. Se vazio, usa mysql quando DB_HOST/DB_NAME/DB_USER existirem; senao sqlite.
DB_DIALECT=

# SQLite (local)
DB_STORAGE=./database.sqlite

# MySQL (deploy/producao)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gestao_empresarial
DB_USER=root
DB_PASSWORD=senha
JWT_SECRET=troque_este_segredo
JWT_EXPIRES_IN=8h
FRONTEND_URL=http://localhost:5173
SEED_ADMIN=true
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=123456
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@empresa.com
